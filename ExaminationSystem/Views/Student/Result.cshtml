        }

        .bar-track {
            width: 100%;
        }
    }

    @@media (max-width: 480px) {
        .summary-grid {
            grid-template-columns: 1fr;
        }

        .chart-legend {
            flex-direction: column;
        }

        .detailed-results,
        .action-panel,
        .comparison-chart {
            padding: 25px;
        }
