@using ExaminationSystem.Entities
@model ExaminationSystem.Entities.Submission

<div class="result-container">
    <!-- Hero Result Section -->
    <div class="hero-section" id="resultHero">
        <div class="hero-content">
            <div class="result-badge animated-badge">
                <div class="badge-circle">
                    <svg width="160" height="160" viewBox="0 0 160 160">
                        <circle class="circle-bg" cx="80" cy="80" r="72"></circle>
                        <circle class="circle-progress" cx="80" cy="80" r="72"
                                stroke-dasharray="452.389"
                                stroke-dashoffset="@@(452.389 * (1 - ((Model.Grade ?? 0) / 100)))"></circle>
                    </svg>
                    <div class="grade-text">
                        <span class="grade-number">@(Model.Grade?.ToString("0.0") ?? "0")</span>
                        <span class="grade-percent">%</span>
                    </div>
                </div>
                <div class="result-title">
                    <h1>Exam Result</h1>
                    <p>@Model.Exam.Title</p>
                </div>
            </div>

            <div class="result-stats">
                <div class="stat-card slide-in-left">
                    <div class="stat-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <div class="stat-content">
                        <h3>@(Model.DurationTakenSeconds.HasValue? Model.DurationTakenSeconds.Value / 60 : 0) min</h3>
                        <p>Time Taken</p>
                    </div>
                </div>
                <div class="stat-card slide-in-left" style="animation-delay: 0.1s">
                    <div class="stat-icon">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                    <div class="stat-content">
                        <h3>@Model.SubmittedAt?.ToString("MMM dd, yyyy")</h3>
                        <p>Submission Date</p>
                    </div>
                </div>
                <div class="stat-card slide-in-left" style="animation-delay: 0.2s">
                    <div class="stat-icon">
                        <i class="fas @((Model.Grade ?? 0) >= 50 ? "fa-trophy" : "fa-redo")"></i>
                    </div>
                    <div class="stat-content">
                        <h3>@((Model.Grade ?? 0) >= 50 ? "Passed" : "Retake")</h3>
                        <p>Status</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Performance Summary -->
        <div class="performance-summary fade-in-up">
            <div class="summary-header">
                <h3><i class="fas fa-chart-bar"></i> Performance Summary</h3>
                <div class="performance-label @GetPerformanceClass(Model.Grade ?? 0)">
                    @GetPerformanceText(Model.Grade ?? 0)
                </div>
            </div>
            <div class="summary-grid">
                <div class="summary-item">
                    <div class="summary-value">@Model.Exam.Questions.Count</div>
                    <div class="summary-label">Total Questions</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value" id="correctAnswers">0</div>
                    <div class="summary-label">Correct Answers</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value" id="wrongAnswers">0</div>
                    <div class="summary-label">Wrong Answers</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Model.Exam.TotalPoints</div>
                    <div class="summary-label">Total Points</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Detailed Results -->
    <div class="detailed-results">
        <div class="section-header">
            <h3><i class="fas fa-list-check"></i> Detailed Review</h3>
            <div class="section-actions">
                <button class="btn-export" onclick="exportResults()">
                    <i class="fas fa-download"></i> Export PDF
                </button>
            </div>
        </div>

        <!-- Questions Review -->
        <div class="questions-review" id="questionsReview">
            @{
                var answers = Model.Answers?.ToList() ?? new List<StudentAnswer>();
                var questions = Model.Exam.Questions?.ToList() ?? new List<Question>();
                int correctCount = 0;
                int wrongCount = 0;
            }

            @for (int i = 0; i < questions.Count; i++)
            {
                var question = questions[i];
                var answer = answers.FirstOrDefault(a => a.QuestionId == question.Id);
                var isCorrect = answer?.Point > 0;
                var choiceLetter = "";

                if (isCorrect) correctCount++;
                else wrongCount++;

                // Get selected choice info
                if (answer?.SelectedChoice != null)
                {
                    var choices = question.Choices?.ToList() ?? new List<Choice>();
                    var selectedIndex = choices.FindIndex(c => c.Id == answer.SelectedChoiceId);
                    choiceLetter = selectedIndex >= 0 ? choices[selectedIndex].ChoiceLetter ?? char.ConvertFromUtf32(65 + selectedIndex).ToString() : "";
                }

                <div class="question-result-card @(isCorrect ? "correct" : "incorrect")">
                    <div class="question-header">
                        <div class="question-number">
                            <span class="number-circle">@(i + 1)</span>
                            <span class="question-status">
                                <i class="fas @(isCorrect ? "fa-check-circle" : "fa-times-circle")"></i>
                                @(isCorrect ? "Correct" : "Incorrect")
                            </span>
                        </div>
                        <div class="question-points">
                            <span class="points-badge @(isCorrect ? "points-earned" : "points-lost")">
                                @(answer?.Point ?? 0) point@(answer?.Point == 1 ? "" : "s")
                            </span>
                        </div>
                    </div>

                    <div class="question-body">
                        <div class="question-text">
                            <p>@question.Body</p>
                        </div>

                        <div class="answer-review">
                            <div class="your-answer">
                                <h5><i class="fas fa-user-check"></i> Your Answer</h5>
                                <div class="answer-content">
                                    @if (answer?.SelectedChoice != null)
                                    {
                                        <span class="choice-letter">@choiceLetter</span>
                                        <span class="choice-text">@answer.SelectedChoice.Body</span>
                                    }
                                    else if (answer?.TFAnswer.HasValue == true)
                                    {
                                        <span class="tf-answer @(answer.TFAnswer.Value ? "true" : "false")">
                                            @(answer.TFAnswer.Value ? "True" : "False")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="no-answer">No answer provided</span>
                                    }
                                </div>
                            </div>

                            @if (!isCorrect)
                            {
                                // Find correct choice for MCQ questions
                                if (question.Type == "MCQ")
                                {
                                    var correctChoice = question.Choices?.FirstOrDefault(c => c.IsCorrect);
                                    if (correctChoice != null)
                                    {
                                        var choices = question.Choices?.ToList() ?? new List<Choice>();
                                        var correctIndex = choices.FindIndex(c => c.Id == correctChoice.Id);
                                        var correctLetter = correctIndex >= 0 ?
                                        choices[correctIndex].ChoiceLetter ?? char.ConvertFromUtf32(65 + correctIndex).ToString() : "";

                                        <div class="correct-answer">
                                            <h5><i class="fas fa-check-double"></i> Correct Answer</h5>
                                            <div class="answer-content">
                                                <span class="choice-letter correct">@correctLetter</span>
                                                <span class="choice-text">@correctChoice.Body</span>
                                            </div>
                                        </div>
                                    }
                                }
                                // Show correct answer for True/False questions
                                else if (question.Type == "TF" && question.CorrectAnswer.HasValue)
                                {
                                    <div class="correct-answer">
                                        <h5><i class="fas fa-check-double"></i> Correct Answer</h5>
                                        <div class="answer-content">
                                            <span class="tf-answer @(question.CorrectAnswer.Value ? "true" : "false")">
                                                @(question.CorrectAnswer.Value ? "True" : "False")
                                            </span>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        <!-- تم إزالة قسم Explanation لأنه غير موجود في الـ Model -->
                    </div>
                </div>
            }

            <script>
                document.getElementById('correctAnswers').textContent = '@correctCount';
                document.getElementById('wrongAnswers').textContent = '@wrongCount';
            </script>
        </div>

        @if (!answers.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-clipboard-question"></i>
                </div>
                <h4>No Detailed Results Available</h4>
                <p>The detailed answers for this exam are not available for review.</p>
            </div>
        }
    </div>

    <!-- Action Panel -->
    <div class="action-panel fade-in-up">
        <div class="panel-header">
            <h3><i class="fas fa-forward"></i> Next Steps</h3>
        </div>
        <div class="action-grid">
            <a asp-action="Index" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-home"></i>
                </div>
                <div class="action-content">
                    <h4>Back to Dashboard</h4>
                    <p>Return to your main dashboard</p>
                </div>
            </a>

            @if (Model.Exam.Course != null)
            {
                <a href="@Url.Action("Details", "Course", new { id = Model.Exam.Course.Id })" class="action-card">
                    <div class="action-icon">
                        <i class="fas fa-book"></i>
                    </div>
                    <div class="action-content">
                        <h4>Course Materials</h4>
                        <p>Review course content</p>
                    </div>
                </a>
            }

            @if ((Model.Grade ?? 0) < 50)
            {
                <a href="@Url.Action("StartExam", new { examId = Model.ExamId })" class="action-card retake">
                    <div class="action-icon">
                        <i class="fas fa-redo"></i>
                    </div>
                    <div class="action-content">
                        <h4>Retake Exam</h4>
                        <p>Try again to improve your score</p>
                    </div>
                </a>
            }

            <button class="action-card" onclick="shareResult()">
                <div class="action-icon">
                    <i class="fas fa-share-alt"></i>
                </div>
                <div class="action-content">
                    <h4>Share Result</h4>
                    <p>Share your achievement</p>
                </div>
            </button>
        </div>
    </div>

    <!-- Comparison Chart -->
    <div class="comparison-chart fade-in-up">
        <div class="chart-header">
            <h3><i class="fas fa-chart-line"></i> Performance Comparison</h3>
            <div class="chart-legend">
                <div class="legend-item">
                    <span class="legend-dot your-grade"></span>
                    <span>Your Grade: @(Model.Grade?.ToString("0.0"))%</span>
                </div>
                <div class="legend-item">
                    <span class="legend-dot class-average"></span>
                    <span>Class Average: 75%</span>
                </div>
                <div class="legend-item">
                    <span class="legend-dot passing-grade"></span>
                    <span>Passing Grade: 50%</span>
                </div>
            </div>
        </div>
        <div class="chart-container">
            <div class="chart-bar">
                <div class="bar-label">Your Grade</div>
                <div class="bar-track">
                    <div class="bar-fill your-grade-fill" style="width: @(Model.Grade ?? 0)%"></div>
                </div>
                <div class="bar-value">@(Model.Grade?.ToString("0.0"))%</div>
            </div>
            <div class="chart-bar">
                <div class="bar-label">Class Average</div>
                <div class="bar-track">
                    <div class="bar-fill class-average-fill" style="width: 75%"></div>
                </div>
                <div class="bar-value">75%</div>
            </div>
            <div class="chart-bar">
                <div class="bar-label">Passing Grade</div>
                <div class="bar-track">
                    <div class="bar-fill passing-grade-fill" style="width: 50%"></div>
                </div>
                <div class="bar-value">50%</div>
            </div>
        </div>
    </div>

    <!-- Celebration Modal for High Scores -->
    @if ((Model.Grade ?? 0) >= 90)
    {
        <div class="celebration-modal" id="celebrationModal">
            <div class="modal-content">
                <div class="modal-body">
                    <div class="confetti-container">
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                    </div>
                    <div class="celebration-icon">
                        <i class="fas fa-trophy fa-4x"></i>
                    </div>
                    <h2>Outstanding Achievement! 🎉</h2>
                    <p class="celebration-message">
                        You scored @(Model.Grade?.ToString("0.0"))%!
                        This is an excellent result. Keep up the great work!
                    </p>
                    <div class="achievement-badge">
                        <i class="fas fa-star"></i>
                        <span>TOP PERFORMER</span>
                    </div>
                    <button class="btn-close-celebration" onclick="closeCelebration()">
                        Continue
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Share Modal -->
    <div class="modal" id="shareModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-share-alt"></i> Share Your Result</h3>
                <button class="modal-close" onclick="closeShareModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="share-preview">
                    <div class="preview-card">
                        <div class="preview-header">
                            <div class="preview-grade">@(Model.Grade?.ToString("0.0"))%</div>
                            <div class="preview-title">@Model.Exam.Title</div>
                        </div>
                        <div class="preview-footer">
                            <span>@DateTime.Now.ToString("MMM dd, yyyy")</span>
                            <span>Examination System</span>
                        </div>
                    </div>
                </div>

                <div class="share-options">
                    <button class="share-option" onclick="copyResultLink()">
                        <i class="fas fa-link"></i>
                        <span>Copy Link</span>
                    </button>
                    <button class="share-option" onclick="shareOnSocial('twitter')">
                        <i class="fab fa-twitter"></i>
                        <span>Twitter</span>
                    </button>
                    <button class="share-option" onclick="shareOnSocial('facebook')">
                        <i class="fab fa-facebook"></i>
                        <span>Facebook</span>
                    </button>
                    <button class="share-option" onclick="downloadResultImage()">
                        <i class="fas fa-image"></i>
                        <span>Save as Image</span>
                    </button>
                </div>

                <div class="share-message">
                    <label for="customMessage">Custom Message</label>
                    <textarea id="customMessage" placeholder="Add a custom message to your shared result...">
I scored @(Model.Grade?.ToString("0.0"))% on @Model.Exam.Title! 🎓
                    </textarea>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    private string GetPerformanceClass(decimal grade)
    {
        if (grade >= 90) return "excellent";
        if (grade >= 75) return "good";
        if (grade >= 50) return "average";
        return "poor";
    }

    private string GetPerformanceText(decimal grade)
    {
        if (grade >= 90) return "Excellent!";
        if (grade >= 75) return "Good Job";
        if (grade >= 50) return "Pass";
        return "Needs Improvement";
    }
}

<style>
    :root {
        --primary-color: #1B3C53;
        --primary-light: #2A4D6E;
        --primary-dark: #0F2838;
        --accent-color: #00D4AA;
        --secondary-color: #4A90E2;
        --success-color: #00C853;
        --warning-color: #FF9800;
        --danger-color: #FF5252;
        --text-primary: #2D3748;
        --text-secondary: #718096;
        --bg-light: #F8FAFC;
        --card-bg: #FFFFFF;
        --border-color: #E2E8F0;
        --shadow-sm: 0 2px 4px rgba(27, 60, 83, 0.06);
        --shadow-md: 0 4px 12px rgba(27, 60, 83, 0.1);
        --shadow-lg: 0 10px 30px rgba(27, 60, 83, 0.15);
        --border-radius: 16px;
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .result-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
        animation: fadeIn 0.8s ease-out;
    }

    /* Hero Section */
    .hero-section {
        background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
        border-radius: var(--border-radius);
        padding: 40px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }

    .hero-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 40px;
        position: relative;
        z-index: 2;
    }

    .result-badge {
        display: flex;
        align-items: center;
        gap: 30px;
    }

    .badge-circle {
        position: relative;
        width: 160px;
        height: 160px;
    }

    .circle-bg {
        fill: none;
        stroke: rgba(255, 255, 255, 0.2);
        stroke-width: 8;
    }

    .circle-progress {
        fill: none;
        stroke: var(--accent-color);
        stroke-width: 8;
        stroke-linecap: round;
        transform: rotate(-90deg);
        transform-origin: 50% 50%;
        transition: stroke-dashoffset 2s ease-in-out;
    }

    .grade-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
    }

    .grade-number {
        font-size: 3.5rem;
        font-weight: 800;
        color: white;
        line-height: 1;
    }

    .grade-percent {
        font-size: 1.5rem;
        color: rgba(255, 255, 255, 0.8);
        font-weight: 600;
    }

    .result-title h1 {
        font-size: 2.5rem;
        color: white;
        margin: 0 0 10px 0;
    }

    .result-title p {
        color: rgba(255, 255, 255, 0.9);
        font-size: 1.2rem;
        margin: 0;
    }

    .result-stats {
        display: flex;
        gap: 20px;
    }

    .stat-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: var(--border-radius);
        padding: 25px;
        min-width: 200px;
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .stat-icon {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.8rem;
    }

    .stat-content h3 {
        color: white;
        margin: 0 0 5px 0;
        font-size: 1.6rem;
    }

    .stat-content p {
        color: rgba(255, 255, 255, 0.8);
        margin: 0;
        font-size: 0.9rem;
    }

    /* Performance Summary */
    .performance-summary {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: var(--border-radius);
        padding: 30px;
        margin-top: 40px;
    }

    .summary-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

        .summary-header h3 {
            color: white;
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 0;
        }

    .performance-label {
        padding: 8px 20px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .performance-label.excellent {
            background: rgba(0, 212, 170, 0.2);
            color: var(--accent-color);
            border: 1px solid var(--accent-color);
        }

        .performance-label.good {
            background: rgba(74, 144, 226, 0.2);
            color: var(--secondary-color);
            border: 1px solid var(--secondary-color);
        }

        .performance-label.average {
            background: rgba(255, 152, 0, 0.2);
            color: var(--warning-color);
            border: 1px solid var(--warning-color);
        }

        .performance-label.poor {
            background: rgba(255, 82, 82, 0.2);
            color: var(--danger-color);
            border: 1px solid var(--danger-color);
        }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
    }

    .summary-item {
        text-align: center;
        padding: 20px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: var(--border-radius);
    }

    .summary-value {
        font-size: 2.5rem;
        font-weight: 800;
        color: white;
        margin-bottom: 8px;
    }

    .summary-label {
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.9rem;
    }

    /* Detailed Results */
    .detailed-results {
        background: var(--card-bg);
        border-radius: var(--border-radius);
        padding: 40px;
        margin-bottom: 40px;
        box-shadow: var(--shadow-md);
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

        .section-header h3 {
            color: var(--primary-color);
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 0;
        }

    .btn-export {
        padding: 10px 25px;
        background: var(--primary-color);
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: var(--transition);
    }

        .btn-export:hover {
            background: var(--primary-light);
            transform: translateY(-2px);
        }

    .questions-review {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .question-result-card {
        background: var(--card-bg);
        border-radius: var(--border-radius);
        border: 2px solid;
        padding: 25px;
        transition: var(--transition);
    }

        .question-result-card.correct {
            border-color: var(--success-color);
            background: linear-gradient(to right, rgba(0, 200, 83, 0.05), transparent);
        }

        .question-result-card.incorrect {
            border-color: var(--danger-color);
            background: linear-gradient(to right, rgba(255, 82, 82, 0.05), transparent);
        }

    .question-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid var(--border-color);
    }

    .question-number {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .number-circle {
        width: 36px;
        height: 36px;
        background: var(--primary-color);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
    }

    .question-status {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
    }

    .question-result-card.correct .question-status {
        color: var(--success-color);
    }

    .question-result-card.incorrect .question-status {
        color: var(--danger-color);
    }

    .points-badge {
        padding: 6px 16px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.9rem;
    }

    .points-earned {
        background: rgba(0, 200, 83, 0.1);
        color: var(--success-color);
        border: 1px solid var(--success-color);
    }

    .points-lost {
        background: rgba(255, 82, 82, 0.1);
        color: var(--danger-color);
        border: 1px solid var(--danger-color);
    }

    .question-body {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .question-text p {
        font-size: 1.1rem;
        line-height: 1.6;
        color: var(--text-primary);
        margin: 0;
    }

    .answer-review {
        display: flex;
        gap: 30px;
        flex-wrap: wrap;
    }

    .your-answer, .correct-answer {
        flex: 1;
        min-width: 300px;
    }

