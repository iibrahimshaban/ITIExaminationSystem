        }

        .summary-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .action-grid {
            grid-template-columns: 1fr;
        }

        .chart-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .chart-bar {
            flex-direction: column;
            align-items: flex-start;
            gap: 10px;
        }

        .bar-label {
