</style>

<script>
    // Exam state
    let examState = {
        totalTime: @Model.DurationInMinutes * 60, // in seconds
        timeRemaining: @Model.DurationInMinutes * 60,
        timeSpent: 0,
        isPaused: false,
        isFullscreen: false,
        answeredQuestions: new Set(),
        reviewQuestions: new Set(),
        currentQuestion: 0,
        timerInterval: null,
        autoSubmitTimeout: null
    };

    document.addEventListener('DOMContentLoaded', function() {
        initializeExam();
        startTimer();
        setupEventListeners();
        updateProgress();
    });

    function initializeExam() {
        // Load saved state from localStorage
        const savedState = localStorage.getItem(`exam_${@Model.ExamId}`);
        if (savedState) {
            const parsedState = JSON.parse(savedState);
            examState = { ...examState, ...parsedState };

            // Restore answers
            examState.answeredQuestions.forEach(questionId => {
                const input = document.querySelector(`input[name="Answers[${questionId}]"]:checked`);
                if (input) {
                    updateQuestionStatus(questionId, true);
                }
            });

            // Restore review flags
            examState.reviewQuestions.forEach(questionNum => {
                const flagBtn = document.getElementById(`flag-${questionNum}`);
                if (flagBtn) {
                    flagBtn.classList.add('active');
                    flagBtn.innerHTML = '<i class="fas fa-flag"></i>';
                    updateNavStatus(questionNum, 'review');
                }
            });
        }

        // Initialize current question
        navigateToQuestion(examState.currentQuestion, false);

        // Start auto-save
        setInterval(saveExamState, 30000); // Save every 30 seconds
    }

    function startTimer() {
        if (examState.timerInterval) {
            clearInterval(examState.timerInterval);
        }

        examState.timerInterval = setInterval(() => {
            if (!examState.isPaused) {
                examState.timeRemaining--;
                examState.timeSpent++;
                document.getElementById('timeSpent').value = examState.timeSpent;

                updateTimerDisplay();

                if (examState.timeRemaining <= 0) {
                    clearInterval(examState.timerInterval);
                    showTimeUpModal();
                } else if (examState.timeRemaining <= 300) { // 5 minutes warning
                    showTimeWarning();
                }
            }
        }, 1000);
    }

    function updateTimerDisplay() {
        const minutes = Math.floor(examState.timeRemaining / 60);
        const seconds = examState.timeRemaining % 60;

        // Update text display
        document.getElementById('timeRemaining').textContent =
            `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        document.getElementById('timerMinutes').textContent = minutes;

        // Update circular timer
        const totalCircumference = 226.194; // 2 * π * 36
        const timeFraction = examState.timeRemaining / examState.totalTime;
        const offset = totalCircumference * (1 - timeFraction);

        document.querySelector('.timer-fill').style.strokeDashoffset = offset;

        // Update pause modal time
        if (document.getElementById('pauseTime')) {
            document.getElementById('pauseTime').textContent =
                `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        }
    }

    function showTimeWarning() {
        const warning = document.getElementById('timeWarning');
        warning.style.display = 'flex';
        warning.style.animation = 'shake 0.5s ease-in-out';
    }

    function togglePause() {
        examState.isPaused = !examState.isPaused;
        const pauseBtn = document.getElementById('pauseBtn');

        if (examState.isPaused) {
            pauseBtn.innerHTML = '<i class="fas fa-play"></i>';
            pauseBtn.style.backgroundColor = 'var(--success-color)';
            pauseBtn.style.color = 'white';
            showPauseModal();
        } else {
            pauseBtn.innerHTML = '<i class="fas fa-pause"></i>';
            pauseBtn.style.backgroundColor = '';
            pauseBtn.style.color = '';
            resumeExam();
        }
    }

    function showPauseModal() {
        document.getElementById('pauseModal').style.display = 'flex';
    }

    function resumeExam() {
        examState.isPaused = false;
        document.getElementById('pauseModal').style.display = 'none';
        startTimer();
    }

    function toggleFullscreen() {
        const elem = document.documentElement;

        if (!examState.isFullscreen) {
            if (elem.requestFullscreen) {
                elem.requestFullscreen();
            } else if (elem.webkitRequestFullscreen) {
                elem.webkitRequestFullscreen();
            } else if (elem.msRequestFullscreen) {
                elem.msRequestFullscreen();
            }
            examState.isFullscreen = true;
        } else {
            if (document.exitFullscreen) {
                document.exitFullscreen();
            } else if (document.webkitExitFullscreen) {
                document.webkitExitFullscreen();
            } else if (document.msExitFullscreen) {
                document.msExitFullscreen();
            }
            examState.isFullscreen = false;
        }
    }

    function toggleSidebar() {
        const sidebar = document.getElementById('questionsSidebar');
        sidebar.classList.toggle('open');
    }

    function scrollToQuestion(index) {
        const questionElement = document.getElementById(`question-${index + 1}`);
        if (questionElement) {
            questionElement.scrollIntoView({ behavior: 'smooth', block: 'start' });

            // Update current question
            document.querySelectorAll('.question-nav-item').forEach(item => {
                item.classList.remove('current');
            });
            document.querySelector(`.question-nav-item[data-question="${index + 1}"]`).classList.add('current');

            examState.currentQuestion = index;
            saveExamState();
        }
    }

    function navigateToQuestion(index, animate = true) {
        scrollToQuestion(index);

        if (animate) {
            const questionElement = document.getElementById(`question-${index + 1}`);
            questionElement.animate([
                { opacity: 0, transform: 'translateY(20px)' },
                { opacity: 1, transform: 'translateY(0)' }
            ], {
                duration: 300,
                easing: 'ease-out'
            });
        }
    }

    function selectChoice(choiceElement, questionIndex, choiceId) {
        const questionNumber = questionIndex + 1;

        // Deselect all choices in this question
        const questionElement = document.getElementById(`question-${questionNumber}`);
        questionElement.querySelectorAll('.choice-item').forEach(item => {
            item.classList.remove('selected');
        });

        // Select clicked choice
        choiceElement.classList.add('selected');

        // Check the radio input
        const radioInput = choiceElement.querySelector('input[type="radio"]');
        radioInput.checked = true;

        // Get question ID from the input name
        const questionId = getQuestionId(questionNumber);

        // Update question status
        updateQuestionStatus(questionId, true);

        // Update progress
        updateProgress();

        // Save state
        saveExamState();

        // Add selection animation
        choiceElement.animate([
            { transform: 'scale(1)' },
            { transform: 'scale(1.02)' },
            { transform: 'scale(1)' }
        ], {
            duration: 200,
            easing: 'ease-out'
        });
    }

    function clearSelection(questionIndex) {
        const questionNumber = questionIndex + 1;

        // Clear all selections in this question
        const questionElement = document.getElementById(`question-${questionNumber}`);
        questionElement.querySelectorAll('.choice-item').forEach(item => {
            item.classList.remove('selected');
        });

        questionElement.querySelectorAll('input[type="radio"]').forEach(input => {
            input.checked = false;
        });

        // Remove from answered questions
        const questionId = getQuestionId(questionNumber);
        examState.answeredQuestions.delete(questionId);

        // Update question status
        updateQuestionStatus(questionId, false);

        // Update progress
        updateProgress();

        // Save state
        saveExamState();

        // Show confirmation
        showNotification('Selection cleared!', 'info');
    }

    function toggleFlag(questionNumber) {
        const flagBtn = document.getElementById(`flag-${questionNumber}`);
        const isActive = flagBtn.classList.toggle('active');

        if (isActive) {
            flagBtn.innerHTML = '<i class="fas fa-flag"></i>';
            examState.reviewQuestions.add(questionNumber);
            updateNavStatus(questionNumber, 'review');
            showNotification('Question marked for review', 'warning');
        } else {
            flagBtn.innerHTML = '<i class="far fa-flag"></i>';
            examState.reviewQuestions.delete(questionNumber);
            const questionId = getQuestionId(questionNumber);
            const isAnswered = examState.answeredQuestions.has(questionId);
            updateNavStatus(questionNumber, isAnswered ? 'answered' : 'unanswered');
        }

        saveExamState();
    }

    function toggleMarkReview(questionNumber) {
        toggleFlag(questionNumber);
    }

    function updateQuestionStatus(questionId, isAnswered) {
        if (isAnswered) {
            examState.answeredQuestions.add(questionId);
        } else {
            examState.answeredQuestions.delete(questionId);
        }

        const questionNumber = getQuestionNumber(questionId);
        if (questionNumber) {
            updateNavStatus(questionNumber,
                examState.reviewQuestions.has(questionNumber) ? 'review' :
                isAnswered ? 'answered' : 'unanswered');
        }
    }

    function updateNavStatus(questionNumber, status) {
        const navItem = document.querySelector(`.question-nav-item[data-question="${questionNumber}"]`);
        const statusElement = document.getElementById(`status-${questionNumber}`);

        if (navItem && statusElement) {
            // Remove all status classes
            navItem.classList.remove('answered', 'review', 'current');
            statusElement.textContent = '';

            // Add appropriate status
            switch(status) {
                case 'answered':
                    navItem.classList.add('answered');
                    statusElement.textContent = '✓';
                    break;
                case 'review':
                    navItem.classList.add('review');
                    statusElement.textContent = '⚑';
                    break;
                case 'current':
                    navItem.classList.add('current');
                    statusElement.textContent = '→';
                    break;
                default:
                    statusElement.textContent = '⏳';
            }
        }
    }

    function updateProgress() {
        const totalQuestions = @Model.Questions.Count;
        const answeredCount = examState.answeredQuestions.size;
        const progressPercent = Math.round((answeredCount / totalQuestions) * 100);

        // Update progress bar
        document.getElementById('examProgress').style.width = `${progressPercent}%`;
        document.getElementById('progressPercent').textContent = progressPercent;
        document.getElementById('answeredCount').textContent = answeredCount;
        document.getElementById('footerAnswered').textContent = answeredCount;

        // Update answered display color based on progress
        const progressBar = document.getElementById('examProgress');
        if (progressPercent < 50) {
            progressBar.style.background = 'linear-gradient(90deg, #FF9800, #FFC107)';
        } else if (progressPercent < 80) {
            progressBar.style.background = 'linear-gradient(90deg, #4A90E2, #00D4AA)';
        } else {
            progressBar.style.background = 'linear-gradient(90deg, #00C853, #00E676)';
        }
    }

    function showReviewModal() {
        const modal = document.getElementById('reviewModal');
        const reviewQuestionsContainer = document.getElementById('reviewQuestions');

        // Update summary
        const totalQuestions = @Model.Questions.Count;
        const answeredCount = examState.answeredQuestions.size;
        const reviewCount = examState.reviewQuestions.size;
        const unansweredCount = totalQuestions - answeredCount;

        document.querySelector('.answered-count').textContent = answeredCount;
        document.querySelector('.review-count').textContent = reviewCount;
        document.querySelector('.unanswered-count').textContent = unansweredCount;

        // Populate questions list
        reviewQuestionsContainer.innerHTML = '';
        for (let i = 0; i < totalQuestions; i++) {
            const questionNumber = i + 1;
            const questionId = getQuestionId(questionNumber);
            let status = 'unanswered';
            let statusClass = 'status-unanswered';

            if (examState.reviewQuestions.has(questionNumber)) {
                status = 'Marked for Review';
                statusClass = 'status-review';
            } else if (examState.answeredQuestions.has(questionId)) {
                status = 'Answered';
                statusClass = 'status-answered';
            } else {
                status = 'Not Answered';
            }

            const questionElement = document.createElement('div');
            questionElement.className = 'review-question-item';
            questionElement.innerHTML = `
                <div class="review-question-number">${questionNumber}</div>
                <div class="review-question-text">Question ${questionNumber}</div>
                <div class="review-question-status ${statusClass}">${status}</div>
            `;

            questionElement.addEventListener('click', () => {
                closeReviewModal();
                navigateToQuestion(i);
            });

            reviewQuestionsContainer.appendChild(questionElement);
        }

        modal.style.display = 'flex';
    }

    function closeReviewModal() {
        document.getElementById('reviewModal').style.display = 'none';
    }

    function showExitModal() {
        document.getElementById('exitModal').style.display = 'flex';
    }

    function closeExitModal() {
        document.getElementById('exitModal').style.display = 'none';
    }

    function confirmExit() {
        const option = document.querySelector('input[name="exitOption"]:checked').value;

        if (option === 'save') {
            saveExamState();
            showNotification('Progress saved. You can resume later.', 'success');
            setTimeout(() => {
                window.location.href = '@Url.Action("Index", "Home")';
            }, 2000);
        } else if (option === 'submit') {
            submitExam();
        } else {
            localStorage.removeItem(`exam_${@Model.ExamId}`);
            window.location.href = '@Url.Action("Index", "Home")';
        }
    }

    function showTimeUpModal() {
        const modal = document.getElementById('timeUpModal');
        modal.style.display = 'flex';

        let countdown = 5;
        const countdownElement = document.getElementById('autoSubmitCountdown');

        const countdownInterval = setInterval(() => {
            countdown--;
            countdownElement.textContent = countdown;

            if (countdown <= 0) {
                clearInterval(countdownInterval);
                submitExam();
            }
        }, 1000);
    }

    function confirmSubmit() {
        const totalQuestions = @Model.Questions.Count;
        const answeredCount = examState.answeredQuestions.size;
        const unansweredCount = totalQuestions - answeredCount;

        if (unansweredCount > 0) {
            const confirmed = confirm(`You have ${unansweredCount} unanswered question(s). Are you sure you want to submit?`);
            return confirmed;
        }
        return true;
    }

    function submitExam() {
        // Clear timers
        clearInterval(examState.timerInterval);
        if (examState.autoSubmitTimeout) {
            clearTimeout(examState.autoSubmitTimeout);
        }

        // Remove saved state
        localStorage.removeItem(`exam_${@Model.ExamId}`);

        // Show loading state
        const submitBtn = document.querySelector('.btn-submit-exam');
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting...';
        submitBtn.disabled = true;

        // Submit form
        document.getElementById('examForm').submit();
    }

    function saveExamState() {
        const state = {
            timeRemaining: examState.timeRemaining,
            timeSpent: examState.timeSpent,
            answeredQuestions: Array.from(examState.answeredQuestions),
            reviewQuestions: Array.from(examState.reviewQuestions),
            currentQuestion: examState.currentQuestion
        };

        localStorage.setItem(`exam_${@Model.ExamId}`, JSON.stringify(state));
    }

    function setupEventListeners() {
        // Fullscreen change event
        document.addEventListener('fullscreenchange', handleFullscreenChange);
        document.addEventListener('webkitfullscreenchange', handleFullscreenChange);
        document.addEventListener('mozfullscreenchange', handleFullscreenChange);
        document.addEventListener('MSFullscreenChange', handleFullscreenChange);

        // Keyboard shortcuts
        document.addEventListener('keydown', handleKeyboardShortcuts);

        // Prevent accidental navigation
        window.addEventListener('beforeunload', handleBeforeUnload);
    }

    function handleFullscreenChange() {
        examState.isFullscreen = !!document.fullscreenElement ||
                                !!document.webkitFullscreenElement ||
                                !!document.mozFullScreenElement ||
                                !!document.msFullscreenElement;
    }

    function handleKeyboardShortcuts(e) {
        // Ctrl/Cmd + S to save
        if ((e.ctrlKey || e.metaKey) && e.key === 's') {
            e.preventDefault();
            saveExamState();
            showNotification('Progress saved!', 'success');
        }

        // Space to pause/resume
        if (e.code === 'Space' && !e.target.matches('input, textarea, button')) {
            e.preventDefault();
            togglePause();
        }

        // Arrow keys for navigation
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
            e.preventDefault();
            if (examState.currentQuestion < @Model.Questions.Count - 1) {
                navigateToQuestion(examState.currentQuestion + 1);
            }
        }

        if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
            e.preventDefault();
            if (examState.currentQuestion > 0) {
                navigateToQuestion(examState.currentQuestion - 1);
            }
        }

        // Number keys to jump to questions
        if (e.key >= '1' && e.key <= '9') {
            const num = parseInt(e.key);
            if (num <= @Model.Questions.Count) {
                e.preventDefault();
                navigateToQuestion(num - 1);
            }
        }

        // F to flag
        if (e.key === 'f' || e.key === 'F') {
            e.preventDefault();
            toggleFlag(examState.currentQuestion + 1);
        }
    }

    function handleBeforeUnload(e) {
        if (examState.answeredQuestions.size > 0) {
            const message = 'You have unsaved exam progress. Are you sure you want to leave?';
            e.returnValue = message;
            return message;
        }
    }

    // Helper function to get question ID by number
    function getQuestionId(questionNumber) {
        // This is a simplified version - you might need to adjust based on your data structure
        // We'll extract the question ID from the input name
        const questionElement = document.getElementById(`question-${questionNumber}`);
        if (questionElement) {
            const radioInput = questionElement.querySelector('input[type="radio"]');
            if (radioInput) {
                const name = radioInput.name;
                // Extract the ID from the name pattern: "Answers[123]"
                const match = name.match(/Answers\[(\d+)\]/);
                if (match && match[1]) {
                    return parseInt(match[1]);
                }
            }
        }
        return 0;
    }

    // Helper function to get question number by ID
    function getQuestionNumber(questionId) {
        // Search through all questions to find the one with matching ID
        for (let i = 1; i <= @Model.Questions.Count; i++) {
            const currentId = getQuestionId(i);
            if (currentId === questionId) {
                return i;
            }
        }
        return null;
    }

    function showNotification(message, type = 'info') {
        const notification = document.createElement('div');
        notification.className = `notification notification-${type}`;
        notification.innerHTML = `
            <i class="fas fa-${type === 'success' ? 'check-circle' : 'info-circle'}"></i>
            <span>${message}</span>
        `;

        notification.style.cssText = `
            position: fixed;
            top: 20px;
            right: 20px;
            background: ${type === 'success' ? '#00C853' : '#1B3C53'};
            color: white;
            padding: 15px 20px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: var(--shadow-lg);
            z-index: 3000;
            animation: slideInRight 0.3s ease-out;
        `;

        document.body.appendChild(notification);

        setTimeout(() => {
            notification.style.animation = 'slideInRight 0.3s ease-out reverse';
            setTimeout(() => notification.remove(), 300);
        }, 3000);
    }

    // Initialize notification styles
    const style = document.createElement('style');
    style.textContent = `
        @@keyframes slideInRight {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
    `;
    document.head.appendChild(style);
</script>