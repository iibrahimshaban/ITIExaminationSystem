@model ExaminationSystem.ViewModel.SolveExamVM

<div class="exam-container">
    <!-- Exam Header with Fixed Navigation -->
    <div class="exam-header fixed-header">
        <div class="header-content">
            <div class="exam-info">
                <h1 class="exam-title">
                    <i class="fas fa-file-alt"></i>
                    @Model.ExamTitle
                </h1>
                <div class="exam-meta">
                    <span class="meta-item">
                        <i class="fas fa-clock"></i>
                        <span id="timeRemaining">--:--</span>
                    </span>
                    <span class="meta-item">
                        <i class="fas fa-question-circle"></i>
                        @Model.Questions.Count Questions
                    </span>
                    <span class="meta-item">
                        <i class="fas fa-star"></i>
                        @(Model.DurationInMinutes) minutes
                    </span>
                </div>
            </div>

            <div class="exam-controls">
                <div class="timer-container">
                    <div class="timer-circle">
                        <svg width="80" height="80" viewBox="0 0 80 80">
                            <circle class="timer-bg" cx="40" cy="40" r="36"></circle>
                            <circle class="timer-fill" cx="40" cy="40" r="36"
                                    stroke-dasharray="226.194" stroke-dashoffset="0"></circle>
                        </svg>
                        <div class="timer-text" id="timerMinutes">@Model.DurationInMinutes</div>
                    </div>
                    <div class="timer-labels">
                        <span>MINUTES</span>
                        <span>REMAINING</span>
                    </div>
                </div>

                <button class="btn-pause" id="pauseBtn" onclick="togglePause()">
                    <i class="fas fa-pause"></i>
                </button>

                <button class="btn-fullscreen" onclick="toggleFullscreen()">
                    <i class="fas fa-expand"></i>
                </button>
            </div>
        </div>

        <!-- Progress Bar -->
        <div class="progress-container">
            <div class="progress-bar">
                <div class="progress-fill" id="examProgress" style="width: 0%"></div>
            </div>
            <div class="progress-text">
                <span>Progress: <span id="progressPercent">0</span>%</span>
                <span>Answered: <span id="answeredCount">0</span>/@Model.Questions.Count</span>
            </div>
        </div>
    </div>

    <!-- Questions Navigation Sidebar -->
    <div class="exam-sidebar" id="questionsSidebar">
        <div class="sidebar-header">
            <h3><i class="fas fa-list-ol"></i> Questions</h3>
            <button class="btn-close-sidebar" onclick="toggleSidebar()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="questions-nav" id="questionsNav">
            @for (int i = 0; i < Model.Questions.Count; i++)
            {
                <a href="#question-@(i + 1)" class="question-nav-item" data-question="@(i + 1)" onclick="scrollToQuestion(@i)">
                    <span class="nav-number">@(i + 1)</span>
                    <span class="nav-status" id="status-@(i + 1)">⏳</span>
                </a>
            }
        </div>
        <div class="sidebar-footer">
            <button class="btn-review" onclick="markForReview()">
                <i class="fas fa-flag"></i> Mark for Review
            </button>
            <div class="legend">
                <div class="legend-item">
                    <span class="legend-dot answered"></span>
                    <span>Answered</span>
                </div>
                <div class="legend-item">
                    <span class="legend-dot review"></span>
                    <span>Review</span>
                </div>
                <div class="legend-item">
                    <span class="legend-dot current"></span>
                    <span>Current</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Exam Content -->
    <div class="exam-content">
        <form asp-action="SubmitExam" method="post" id="examForm" class="exam-form">
            <input type="hidden" name="ExamId" value="@Model.ExamId" />
            <input type="hidden" id="timeSpent" name="TimeSpent" value="0" />

            @for (int i = 0; i < Model.Questions.Count; i++)
            {
                var question = Model.Questions[i];
                <div class="question-section" id="question-@(i + 1)" data-question="@(i + 1)">
                    <div class="question-header">
                        <div class="question-number">
                            <span class="number-badge">Question @(i + 1) of @Model.Questions.Count</span>
                            <button class="btn-flag" onclick="toggleFlag(@(i + 1))" id="flag-@(i + 1)">
                                <i class="far fa-flag"></i>
                            </button>
                        </div>
                        <div class="question-points">
                            <i class="fas fa-star"></i>
                            <span>1 point</span>
                        </div>
                    </div>

                    <div class="question-body">
                        <div class="question-text">
                            <p>@question.Body</p>
                            <!-- تم إزالة جزء الصورة لأن ViewModel لا يحتوي على ImageUrl -->
                        </div>

                        <div class="choices-container">
                            @if (question.Choices?.Any() == true)
                            {
                                var choiceIndex = 0;
                                foreach (var choice in question.Choices)
                                {
                                    <div class="choice-item" onclick="selectChoice(this, @i, @choice.ChoiceId)">
                                        <div class="choice-radio">
                                            <input type="radio"
                                                   id="choice-@i-@choice.ChoiceId"
                                                   name="Answers[@question.QuestionId]"
                                                   value="@choice.ChoiceId"
                                                   class="choice-input"
                                                   onchange="updateProgress()">
                                            <div class="radio-custom"></div>
                                        </div>
                                        <label for="choice-@i-@choice.ChoiceId" class="choice-label">
                                            <span class="choice-letter">@(char.ConvertFromUtf32(65 + choiceIndex))</span>
                                            <span class="choice-text">@choice.Body</span>
                                        </label>
                                    </div>
                                    choiceIndex++;
                                }
                            }
                            else
                            {
                                <div class="empty-choices">
                                    <p>No choices available for this question.</p>
                                </div>
                            }
                        </div>

                        <div class="question-actions">
                            <button type="button" class="btn-clear" onclick="clearSelection(@i)">
                                <i class="fas fa-times"></i> Clear Selection
                            </button>
                            <button type="button" class="btn-mark-review" onclick="toggleMarkReview(@(i + 1))">
                                <i class="fas fa-flag"></i> Mark for Review
                            </button>
                        </div>
                    </div>

                    <!-- Navigation Buttons -->
                    <div class="question-navigation">
                        @if (i > 0)
                        {
                            <button type="button" class="btn-prev" onclick="navigateToQuestion(@(i - 1))">
                                <i class="fas fa-chevron-left"></i> Previous
                            </button>
                        }
                        @if (i < Model.Questions.Count - 1)
                        {
                            <button type="button" class="btn-next" onclick="navigateToQuestion(@(i + 1))">
                                Next <i class="fas fa-chevron-right"></i>
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn-review-all" onclick="showReviewModal()">
                                <i class="fas fa-clipboard-check"></i> Review All
                            </button>
                        }
                    </div>
                </div>
            }

            <!-- Submit Section -->
            <div class="submit-section">
                <div class="submit-warning">
                    <div class="warning-icon">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <div class="warning-content">
                        <h4>Before You Submit</h4>
                        <p>Please review all questions. Once submitted, you cannot change your answers.</p>
                    </div>
                </div>

                <div class="submit-actions">
                    <button type="button" class="btn-return" onclick="showReviewModal()">
                        <i class="fas fa-eye"></i> Review Answers
                    </button>
                    <button type="submit" class="btn-submit-exam" onclick="return confirmSubmit()">
                        <i class="fas fa-paper-plane"></i> Submit Exam
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Fixed Bottom Bar -->
    <div class="exam-footer fixed-footer">
        <div class="footer-left">
            <button class="btn-toggle-sidebar" onclick="toggleSidebar()">
                <i class="fas fa-bars"></i>
                <span>Questions</span>
            </button>
            <div class="answered-display">
                <span id="footerAnswered">0</span>/@Model.Questions.Count answered
            </div>
        </div>
        <div class="footer-center">
            <div class="time-warning" id="timeWarning">
                <i class="fas fa-clock"></i>
                <span>Time is running!</span>
            </div>
        </div>
        <div class="footer-right">
            <button class="btn-exit" onclick="showExitModal()">
                <i class="fas fa-sign-out-alt"></i> Exit
            </button>
        </div>
    </div>

    <!-- Review Modal -->
    <div class="modal" id="reviewModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-clipboard-check"></i> Review Answers</h3>
                <button class="modal-close" onclick="closeReviewModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="review-summary">
                    <div class="summary-item">
                        <span class="summary-count answered-count">0</span>
                        <span class="summary-label">Answered</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-count review-count">0</span>
                        <span class="summary-label">Marked for Review</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-count unanswered-count">@Model.Questions.Count</span>
                        <span class="summary-label">Unanswered</span>
                    </div>
                </div>

                <div class="review-questions" id="reviewQuestions">
                    <!-- Questions will be populated here -->
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeReviewModal()">Continue Exam</button>
                <button class="btn-submit-final" onclick="submitExam()">Submit Now</button>
            </div>
        </div>
    </div>

    <!-- Pause Modal -->
    <div class="modal" id="pauseModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-pause"></i> Exam Paused</h3>
            </div>
            <div class="modal-body">
                <div class="pause-timer">
                    <i class="fas fa-clock fa-3x"></i>
                    <div class="pause-time" id="pauseTime">--:--</div>
                </div>
                <p class="pause-message">Your exam timer has been paused. Click "Resume" to continue.</p>
            </div>
            <div class="modal-footer">
                <button class="btn-resume" onclick="resumeExam()">
                    <i class="fas fa-play"></i> Resume Exam
                </button>
            </div>
        </div>
    </div>

    <!-- Exit Modal -->
    <div class="modal" id="exitModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-exclamation-triangle"></i> Exit Exam?</h3>
                <button class="modal-close" onclick="closeExitModal()">&times;</button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to exit the exam? Your progress will be saved, but you will need to resume later.</p>
                <div class="exit-options">
                    <label>
                        <input type="radio" name="exitOption" value="save" checked>
                        Save and Exit
                    </label>
                    <label>
                        <input type="radio" name="exitOption" value="submit">
                        Submit Now
                    </label>
                    <label>
                        <input type="radio" name="exitOption" value="discard">
                        Discard and Exit
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeExitModal()">Cancel</button>
                <button class="btn-confirm-exit" onclick="confirmExit()">Confirm</button>
            </div>
        </div>
    </div>

    <!-- Image Modal - تم إزالته لأن ViewModel لا يحتوي على صور -->
    <!-- Time Up Modal -->
    <div class="modal" id="timeUpModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-hourglass-end"></i> Time's Up!</h3>
            </div>
            <div class="modal-body">
                <div class="timeup-icon">
                    <i class="fas fa-clock fa-4x"></i>
                </div>
                <p>Your exam time has ended. The exam will be submitted automatically.</p>
                <div class="timeup-countdown">
                    Submitting in <span id="autoSubmitCountdown">5</span> seconds...
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* نفس الـ CSS السابق بدون تغيير */
    :root {
        --primary-color: #1B3C53;
        --primary-light: #2A4D6E;
        --primary-dark: #0F2838;
        --accent-color: #00D4AA;
        --secondary-color: #4A90E2;
        --success-color: #00C853;
        --warning-color: #FF9800;
        --danger-color: #FF5252;
        --text-primary: #2D3748;
        --text-secondary: #718096;
        --bg-light: #F8FAFC;
        --card-bg: #FFFFFF;
        --border-color: #E2E8F0;
        --shadow-sm: 0 2px 4px rgba(27, 60, 83, 0.06);
        --shadow-md: 0 4px 12px rgba(27, 60, 83, 0.1);
        --shadow-lg: 0 10px 30px rgba(27, 60, 83, 0.15);
        --border-radius: 12px;
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #f8fafc 0%, #e8f4fd 100%);
        min-height: 100vh;
        color: var(--text-primary);
    }

    .exam-container {
        max-width: 1400px;
        margin: 0 auto;
        padding-top: 120px;
        padding-bottom: 80px;
        position: relative;
        min-height: 100vh;
    }

    /* Fixed Header */
    .fixed-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        background: white;
        box-shadow: var(--shadow-md);
        z-index: 1000;
        padding: 15px 0;
    }

    .header-content {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .exam-info {
        flex: 1;
    }

    .exam-title {
        font-size: 1.5rem;
        color: var(--primary-color);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .exam-title i {
            color: var(--accent-color);
        }

    .exam-meta {
        display: flex;
        gap: 20px;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

        .meta-item i {
            color: var(--primary-color);
        }

    #timeRemaining {
        font-family: 'Courier New', monospace;
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--primary-color);
    }

    .exam-controls {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .timer-container {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .timer-circle {
        position: relative;
        width: 80px;
        height: 80px;
    }

    .timer-bg {
        fill: none;
        stroke: var(--border-color);
        stroke-width: 8;
    }

    .timer-fill {
        fill: none;
        stroke: var(--accent-color);
        stroke-width: 8;
        stroke-linecap: round;
        transform: rotate(-90deg);
        transform-origin: 50% 50%;
        transition: stroke-dashoffset 1s linear;
    }

    .timer-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--primary-color);
    }

    .timer-labels {
        display: flex;
        flex-direction: column;
        font-size: 0.75rem;
        color: var(--text-secondary);
        line-height: 1.2;
    }

    .btn-pause, .btn-fullscreen {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 2px solid var(--border-color);
        background: white;
        color: var(--text-secondary);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        transition: var(--transition);
    }

        .btn-pause:hover, .btn-fullscreen:hover {
            border-color: var(--primary-color);
            color: var(--primary-color);
            transform: scale(1.1);
        }

    .progress-container {
        max-width: 1400px;
        margin: 15px auto 0;
        padding: 0 20px;
    }

    .progress-bar {
        height: 6px;
        background: var(--border-color);
        border-radius: 3px;
        overflow: hidden;
        margin-bottom: 8px;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--accent-color), var(--secondary-color));
        border-radius: 3px;
        transition: width 0.3s ease;
    }

    .progress-text {
        display: flex;
        justify-content: space-between;
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    /* Sidebar */
    .exam-sidebar {
        position: fixed;
        left: -300px;
        top: 120px;
        width: 300px;
        height: calc(100vh - 200px);
        background: white;
        box-shadow: var(--shadow-lg);
        border-radius: 0 var(--border-radius) var(--border-radius) 0;
        z-index: 999;
        transition: left 0.3s ease;
        overflow-y: auto;
    }

        .exam-sidebar.open {
            left: 0;
        }

    .sidebar-header {
        padding: 20px;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .sidebar-header h3 {
            color: var(--primary-color);
            display: flex;
            align-items: center;
            gap: 10px;
        }

    .btn-close-sidebar {
        background: none;
        border: none;
        font-size: 1.2rem;
        color: var(--text-secondary);
        cursor: pointer;
        transition: var(--transition);
    }

        .btn-close-sidebar:hover {
            color: var(--primary-color);
        }

    .questions-nav {
        padding: 20px;
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
    }

    .question-nav-item {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        border: 2px solid var(--border-color);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: var(--text-primary);
        transition: var(--transition);
        cursor: pointer;
        position: relative;
    }

        .question-nav-item:hover {
            border-color: var(--primary-color);
            transform: translateY(-2px);
        }

        .question-nav-item.current {
            border-color: var(--primary-color);
            background: var(--primary-color);
            color: white;
        }

        .question-nav-item.answered {
            border-color: var(--success-color);
            background: rgba(0, 200, 83, 0.1);
        }

        .question-nav-item.review {
            border-color: var(--warning-color);
            background: rgba(255, 152, 0, 0.1);
        }

    .nav-number {
        font-size: 1rem;
        font-weight: 600;
    }

    .nav-status {
        font-size: 0.7rem;
        margin-top: 2px;
    }

    .sidebar-footer {
        padding: 20px;
        border-top: 1px solid var(--border-color);
    }

    .btn-review {
        width: 100%;
        padding: 12px;
        background: var(--warning-color);
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: var(--transition);
        margin-bottom: 20px;
    }

        .btn-review:hover {
            background: #E68A00;
            transform: translateY(-2px);
        }

    .legend {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    .legend-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

        .legend-dot.answered {
            background: var(--success-color);
        }

        .legend-dot.review {
            background: var(--warning-color);
        }

        .legend-dot.current {
            background: var(--primary-color);
        }

    /* Main Content */
    .exam-content {
        max-width: 900px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .exam-form {
        display: flex;
        flex-direction: column;
        gap: 40px;
    }

    .question-section {
        background: white;
        border-radius: var(--border-radius);
        padding: 30px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--border-color);
        animation: fadeInUp 0.5s ease-out;
    }

    .question-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 2px solid var(--bg-light);
    }

    .question-number {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .number-badge {
        background: var(--primary-color);
        color: white;
        padding: 8px 20px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .btn-flag {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 2px solid var(--border-color);
        background: white;
        color: var(--text-secondary);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
    }

        .btn-flag:hover, .btn-flag.active {
            border-color: var(--warning-color);
            color: var(--warning-color);
            background: rgba(255, 152, 0, 0.1);
        }

    .question-points {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--accent-color);
        font-weight: 600;
    }

    .question-text {
        margin-bottom: 30px;
        line-height: 1.6;
    }

        .question-text p {
            font-size: 1.1rem;
            margin-bottom: 20px;
        }

    .choices-container {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 25px;
    }

    .choice-item {
        display: flex;
        align-items: center;
        padding: 15px 20px;
        border: 2px solid var(--border-color);
        border-radius: var(--border-radius);
        cursor: pointer;
        transition: var(--transition);
        background: white;
    }

        .choice-item:hover {
            border-color: var(--primary-light);
            background: var(--bg-light);
            transform: translateX(5px);
        }

        .choice-item.selected {
            border-color: var(--accent-color);
            background: rgba(0, 212, 170, 0.1);
        }

    .choice-radio {
        position: relative;
        margin-right: 15px;
    }

    .choice-input {
        position: absolute;
        opacity: 0;
        cursor: pointer;
    }

    .radio-custom {
        width: 22px;
        height: 22px;
        border: 2px solid var(--border-color);
        border-radius: 50%;
        position: relative;
        transition: var(--transition);
    }

    .choice-input:checked ~ .radio-custom {
        border-color: var(--accent-color);
        background: var(--accent-color);
    }

    .radio-custom::after {
        content: '';
        position: absolute;
