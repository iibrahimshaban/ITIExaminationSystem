@model SolveExamVM
<link rel="stylesheet" href="~/css/exam.css" />

<div class="exam-header">
    <h2>@Model.ExamTitle</h2>
    <div id="timer"></div>
</div>

<form asp-action="SubmitExam" method="post">
    <input type="hidden" name="ExamId" value="@Model.ExamId" />

    @for (int i = 0; i < Model.Questions.Count; i++)
    {
        <div class="question-card">
            <h4>Question @(i + 1)</h4>
            <p>@Model.Questions[i].Body</p>

            @foreach (var c in Model.Questions[i].Choices ?? new())
            {
                <label>
                    <input type="radio"
                           name="Answers[@Model.Questions[i].QuestionId]"
                           value="@c.ChoiceId" /> @c.Body
                </label>
        
                <br />
            }
        </div>
    }

    <button class="submit-btn">Submit Exam</button>
</form>

<script src="~/js/exam-timer.js"></script>
<script>
    startTimer(@Model.DurationInMinutes * 60);
</script>
