@model InstructorExamDetailsVm

@{
    ViewData["Title"] = "Exam Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-action="Index" asp-controller="Instructor">
                    <i class="bi bi-house-door me-1"></i>Dashboard
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="MyCourses" asp-controller="Instructor">My Courses</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Exam Details</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="d-flex align-items-center mb-4">
        <div class="icon-wrapper bg-primary bg-opacity-10 rounded-circle p-3 me-3">
            <i class="bi bi-file-earmark-text iconecolor fs-2"></i>
        </div>
        <div>
            <h2 class="mb-1">Exam Assignment</h2>
            <p class="text-muted mb-0">Configure and assign exam to students</p>
        </div>
    </div>

    <!-- Main Card -->
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-gear iconecolor me-2"></i>Exam Configuration
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="AssignExam" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ExamId" />

                        <!-- Information Alert -->
                        <div class="alert alert-info mb-4" role="alert">
                            <div class="d-flex align-items-start">
                                <i class="bi bi-info-circle fs-4 me-3"></i>
                                <div>
                                    <h6 class="alert-heading mb-2">Exam Assignment Information</h6>
                                    <p class="mb-0 small">
                                        Configure the number of questions students will receive and set the maximum number of students who can take this exam.
                                        The system will randomly select questions from your question bank based on these settings.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Question Configuration Section -->
                        <div class="mb-4">
                            <h6 class="text-primary mb-3">
                                <i class="bi bi-list-check me-2"></i>Question Distribution
                            </h6>

                            <div class="row g-4">
                                <!-- MCQ Questions -->
                                <div class="col-md-6">
                                    <div class="card bg-light border-0 h-100">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <div class="icon-wrapper bg-primary bg-opacity-10 rounded p-2 me-3">
                                                    <i class="bi bi-list-ul iconecolor fs-4"></i>
                                                </div>
                                                <div>
                                                    <label asp-for="NumberOfMCQ" class="form-label fw-semibold mb-1">
                                                        Multiple Choice Questions
                                                        <span class="text-danger">*</span>
                                                    </label>
                                                    <small class="text-muted d-block">Number of MCQ questions per exam</small>
                                                </div>
                                            </div>
                                            <input asp-for="NumberOfMCQ"
                                                   type="number"
                                                   min="0"
                                                   class="form-control form-control-lg"
                                                   placeholder="e.g., 10" />
                                            <span asp-validation-for="NumberOfMCQ" class="text-danger small"></span>
                                            <div class="form-text mt-2">
                                                <i class="bi bi-lightbulb me-1"></i>
                                                Minimum recommended: 7 questions
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- True/False Questions -->
                                <div class="col-md-6">
                                    <div class="card bg-light border-0 h-100">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center mb-3">
                                                <div class="icon-wrapper bg-primary bg-opacity-10 rounded p-2 me-3">
                                                    <i class="bi bi-toggle-on iconecolor fs-4"></i>
                                                </div>
                                                <div>
                                                    <label asp-for="NumberOfTrueFalse" class="form-label fw-semibold mb-1">
                                                        True / False Questions
                                                        <span class="text-danger">*</span>
                                                    </label>
                                                    <small class="text-muted d-block">Number of True/False questions per exam</small>
                                                </div>
                                            </div>
                                            <input asp-for="NumberOfTrueFalse"
                                                   type="number"
                                                   min="0"
                                                   class="form-control form-control-lg"
                                                   placeholder="e.g., 5" />
                                            <span asp-validation-for="NumberOfTrueFalse" class="text-danger small"></span>
                                            <div class="form-text mt-2">
                                                <i class="bi bi-lightbulb me-1"></i>
                                                Minimum recommended: 3 questions
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Student Capacity Section -->
                        <div class="mb-4">
                            <h6 class="text-primary mb-3">
                                <i class="bi bi-people me-2"></i>Student Capacity
                            </h6>

                            <div class="card border-primary border-opacity-25">
                                <div class="card-body">
                                    <div class="row align-items-center">
                                        <div class="col-md-3">
                                            <div class="icon-wrapper bg-primary bg-opacity-10 rounded-circle p-4 d-inline-flex">
                                                <i class="bi bi-person-check iconecolor fs-1"></i>
                                            </div>
                                        </div>
                                        <div class="col-md-9">
                                            <label asp-for="MaxStudents" class="form-label fw-semibold mb-2">
                                                Maximum Number of Students
                                                <span class="text-danger">*</span>
                                            </label>
                                            <input asp-for="MaxStudents"
                                                   type="number"
                                                   min="1"
                                                   class="form-control form-control-lg"
                                                   placeholder="e.g., 50" />
                                            <span asp-validation-for="MaxStudents" class="text-danger small d-block mt-1"></span>
                                            <div class="form-text mt-2">
                                                <i class="bi bi-info-circle me-1"></i>
                                                Set the maximum number of students who can take this exam. This helps manage exam capacity and resources.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Summary Preview -->
                        <div class="card bg-success bg-opacity-10 border-success mb-4">
                            <div class="card-body">
                                <h6 class="text-success mb-3">
                                    <i class="bi bi-check-circle me-2"></i>Exam Summary
                                </h6>
                                <div class="row text-center g-3">
                                    <div class="col-md-4">
                                        <div class="p-3">
                                            <i class="bi bi-list-check text-primary fs-2 d-block mb-2"></i>
                                            <strong class="d-block fs-4 text-primary" id="mcqPreview">-</strong>
                                            <small class="text-muted">MCQ Questions</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="p-3">
                                            <i class="bi bi-toggle-on text-primary fs-2 d-block mb-2"></i>
                                            <strong class="d-block fs-4 text-primary" id="tfPreview">-</strong>
                                            <small class="text-muted">True/False Questions</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="p-3">
                                            <i class="bi bi-people text-primary fs-2 d-block mb-2"></i>
                                            <strong class="d-block fs-4 text-primary" id="studentsPreview">-</strong>
                                            <small class="text-muted">Max Students</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-center mt-3 pt-3 border-top border-success border-opacity-25">
                                    <strong class="text-success">Total Questions per Exam: </strong>
                                    <span class="badge bg-success fs-6 px-3 py-2" id="totalPreview">0</span>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex gap-3 justify-content-end pt-3 border-top">
                            <a asp-action="Exams" asp-controller="Instructor" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle me-2"></i>Assign Exam to Students
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Help Card -->
            <div class="card border-0 bg-light mt-4">
                <div class="card-body">
                    <h6 class="mb-3">
                        <i class="bi bi-question-circle text-primary me-2"></i>Need Help?
                    </h6>
                    <ul class="mb-0 small">
                        <li class="mb-2">
                            <strong>Question Distribution:</strong> The system will randomly select the specified number of questions from your question bank for each student.
                        </li>
                        <li class="mb-2">
                            <strong>Student Capacity:</strong> Once the maximum number of students is reached, no additional students will be able to access this exam.
                        </li>
                        <li>
                            <strong>Best Practice:</strong> Ensure you have enough questions in your bank to provide variety across different student attempts.
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>


<style>
    :root {
        --primary-color: #1B3C53;
        --secondary-color: #456882;
        --accent-color: #D2C1B6;
        --background-color: #F9F3EF;
    }

    .bg-primary {
        background-color: var(--primary-color) !important;
    }

    .text-primary {
        color: var(--primary-color) !important;
    }

    .btn-primary {
        background-color: var(--primary-color);
        border-color: var(--primary-color);
        font-size: 1.1rem;
        padding: 0.75rem 2rem;
    }

        .btn-primary:hover {
            background-color: var(--secondary-color);
            border-color: var(--secondary-color);
        }

    .btn-outline-secondary {
        color: var(--secondary-color);
        border-color: var(--secondary-color);
        font-size: 1.1rem;
        padding: 0.75rem 2rem;
    }

        .btn-outline-secondary:hover {
            background-color: var(--secondary-color);
            border-color: var(--secondary-color);
            color: #fff;
        }

    .breadcrumb-item a {
        color: var(--primary-color);
        text-decoration: none;
    }

        .breadcrumb-item a:hover {
            color: var(--secondary-color);
            text-decoration: underline;
        }

    .breadcrumb-item.active {
        color: var(--secondary-color);
    }

    .card {
        border-radius: 0.75rem;
        transition: transform 0.2s ease;
    }

        .card:hover {
            transform: translateY(-2px);
        }

    .card-header {
        border-top-left-radius: 0.75rem;
        border-top-right-radius: 0.75rem;
    }

    .icon-wrapper {
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .form-control:focus {
        border-color: var(--secondary-color);
        box-shadow: 0 0 0 0.2rem rgba(69, 104, 130, 0.25);
    }

    .form-control-lg {
        font-size: 1.1rem;
        padding: 0.75rem 1rem;
    }

    .alert {
        border-radius: 0.5rem;
    }

    .border-primary {
        border-color: var(--primary-color) !important;
    }
    .iconecolor
    {
        color:white
    }
</style>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const mcqInput = document.querySelector('input[name="NumberOfMCQ"]');
            const tfInput = document.querySelector('input[name="NumberOfTrueFalse"]');
            const studentsInput = document.querySelector('input[name="MaxStudents"]');

            const mcqPreview = document.getElementById('mcqPreview');
            const tfPreview = document.getElementById('tfPreview');
            const studentsPreview = document.getElementById('studentsPreview');
            const totalPreview = document.getElementById('totalPreview');

            function updatePreview() {
                const mcqValue = parseInt(mcqInput.value) || 0;
                const tfValue = parseInt(tfInput.value) || 0;
                const studentsValue = parseInt(studentsInput.value) || 0;
                const total = mcqValue + tfValue;

                mcqPreview.textContent = mcqValue > 0 ? mcqValue : '-';
                tfPreview.textContent = tfValue > 0 ? tfValue : '-';
                studentsPreview.textContent = studentsValue > 0 ? studentsValue : '-';
                totalPreview.textContent = total;

                // Update colors based on recommendations
                if (mcqValue >= 7) {
                    mcqPreview.classList.remove('text-warning');
                    mcqPreview.classList.add('text-success');
                } else if (mcqValue > 0) {
                    mcqPreview.classList.remove('text-success');
                    mcqPreview.classList.add('text-warning');
                } else {
                    mcqPreview.classList.remove('text-success', 'text-warning');
                    mcqPreview.classList.add('text-primary');
                }

                if (tfValue >= 3) {
                    tfPreview.classList.remove('text-warning');
                    tfPreview.classList.add('text-success');
                } else if (tfValue > 0) {
                    tfPreview.classList.remove('text-success');
                    tfPreview.classList.add('text-warning');
                } else {
                    tfPreview.classList.remove('text-success', 'text-warning');
                    tfPreview.classList.add('text-primary');
                }
            }

            mcqInput.addEventListener('input', updatePreview);
            tfInput.addEventListener('input', updatePreview);
            studentsInput.addEventListener('input', updatePreview);

            // Initial update
            updatePreview();
        });
    </script>
}
