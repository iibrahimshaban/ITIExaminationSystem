

@model ExamQuestionsSummaryVm

@{
    ViewData["Title"] = "Publish Exam";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-action="Index" asp-controller="Instructor">
                    <i class="bi bi-house-door me-1"></i>Dashboard
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="UnpublishedExams" asp-controller="Instructor">Unpublished Exams</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="ListQuestions" asp-controller="Instructor" asp-route-examId="@Model.ExamId">
                    Questions
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Publish</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="mb-4 text-center">
        <div class="mb-3">
            <i class="bi bi-megaphone text-warning" style="font-size: 4rem;"></i>
        </div>
        <h2 class="mb-2">Publish Exam</h2>
        <p class="text-muted">You are about to publish this exam</p>
    </div>

    <!-- Confirmation Card -->
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-warning bg-opacity-10 border-bottom border-warning py-3">
                    <h5 class="mb-0 text-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>Confirm Publication
                    </h5>
                </div>
                <div class="card-body p-4">
                    <!-- Exam Title -->
                    <div class="mb-4 text-center">
                        <h4 class="text-primary mb-3">@Model.ExamTitle</h4>
                    </div>

                    <!-- Exam Statistics -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="card bg-light border-0">
                                <div class="card-body text-center">
                                    <i class="bi bi-list-check text-primary fs-1 mb-2"></i>
                                    <h3 class="mb-1 text-success fw-bold">@Model.MCQCount</h3>
                                    <p class="text-muted mb-0">MCQ Questions</p>
                                    <small class="text-success">
                                        <i class="bi bi-check-circle me-1"></i>Minimum: 7
                                    </small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light border-0">
                                <div class="card-body text-center">
                                    <i class="bi bi-toggle-on text-primary fs-1 mb-2"></i>
                                    <h3 class="mb-1 text-success fw-bold">@Model.TrueFalseCount</h3>
                                    <p class="text-muted mb-0">True/False Questions</p>
                                    <small class="text-success">
                                        <i class="bi bi-check-circle me-1"></i>Minimum: 3
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Warning Message -->
                    <div class="alert alert-warning mb-4" role="alert">
                        <div class="d-flex align-items-start">
                            <i class="bi bi-info-circle fs-4 me-3"></i>
                            <div>
                                <h6 class="alert-heading mb-2">Important Information</h6>
                                <ul class="mb-0">
                                    <li>Once published, this exam will be <strong>visible to all students</strong> in the course</li>
                                    <li>Students will be able to take this exam</li>
                                    <li>You can still manage the exam after publishing</li>
                                    <li>All questions have been validated and meet the requirements</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Checklist -->
                    <div class="card bg-success bg-opacity-10 border-success mb-4">
                        <div class="card-body">
                            <h6 class="text-success mb-3">
                                <i class="bi bi-check-circle me-2"></i>Requirements Met
                            </h6>
                            <ul class="list-unstyled mb-0">
                                <li class="mb-2">
                                    <i class="bi bi-check-lg text-success me-2"></i>
                                    <strong>@Model.MCQCount MCQ questions</strong> (minimum 7 required)
                                </li>
                                <li class="mb-2">
                                    <i class="bi bi-check-lg text-success me-2"></i>
                                    <strong>@Model.TrueFalseCount True/False questions</strong> (minimum 3 required)
                                </li>
                                <li class="mb-2">
                                    <i class="bi bi-check-lg text-success me-2"></i>
                                    All questions have been validated
                                </li>
                                <li class="mb-0">
                                    <i class="bi bi-check-lg text-success me-2"></i>
                                    Exam is ready for students
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Confirmation Form -->
                    <form asp-action="PublishExam" method="post" class="mb-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="examId" value="@Model.ExamId" />

                        <div class="d-flex gap-3 justify-content-center pt-3 border-top">
                            <a asp-action="ListQuestions" asp-controller="Instructor" asp-route-examId="@Model.ExamId"
                               class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-megaphone me-2"></i>Publish Exam Now
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Back Link -->
            <div class="text-center mt-4">
                <a asp-action="ListQuestions" asp-controller="Instructor" asp-route-examId="@Model.ExamId"
                   class="text-muted">
                    <i class="bi bi-arrow-left me-1"></i>Back to Questions
                </a>
            </div>
        </div>
    </div>
</div>


    <style>
        :root {
            --primary-color: #1B3C53;
            --secondary-color: #456882;
            --accent-color: #D2C1B6;
            --background-color: #F9F3EF;
        }

        .bg-primary {
            background-color: var(--primary-color) !important;
        }

        .text-primary {
            color: var(--primary-color) !important;
        }

        .btn-success {
            font-size: 1.1rem;
            padding: 0.75rem 2rem;
        }

        .btn-outline-secondary {
            color: var(--secondary-color);
            border-color: var(--secondary-color);
            font-size: 1.1rem;
            padding: 0.75rem 2rem;
        }

        .btn-outline-secondary:hover {
            background-color: var(--secondary-color);
            border-color: var(--secondary-color);
            color: #fff;
        }

        .breadcrumb-item a {
            color: var(--primary-color);
            text-decoration: none;
        }

        .breadcrumb-item a:hover {
            color: var(--secondary-color);
            text-decoration: underline;
        }

        .breadcrumb-item.active {
            color: var(--secondary-color);
        }

        .card {
            border-radius: 0.75rem;
        }

        .card-header {
            border-top-left-radius: 0.75rem;
            border-top-right-radius: 0.75rem;
        }

        .alert {
            border-radius: 0.5rem;
        }
    </style>



